# GlobalScholar AI - Environment Variables Template
# Copy this to .env.local and fill in your values

# ============================================
# APP
# ============================================
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=GlobalScholar AI
NEXT_PUBLIC_SITE_URL=https://globalscholar.ai

# ============================================
# AI PROVIDERS (at least one required for AI features)
# DeepSeek is recommended (cheapest, fastest)
# ============================================
DEEPSEEK_API_KEY=
OPENROUTER_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
CLAUDE_API_KEY=

# ============================================
# SEARCH ENGINE
# ============================================
MEILISEARCH_HOST=http://localhost:7700
MEILISEARCH_API_KEY=

# ============================================
# DATABASE
# ============================================
# Supabase (primary database)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# PocketBase (alternative/legacy)
POCKETBASE_URL=http://localhost:8090
POCKETBASE_ADMIN_EMAIL=admin@globalscholar.ai
POCKETBASE_ADMIN_PASSWORD=admin123

# ============================================
# STORAGE
# ============================================
# Supabase Storage (files, images)
# Uses same Supabase credentials above

# ============================================
# AUTH
# ============================================
JWT_SECRET=change-this-to-a-secure-random-string-in-production

# ============================================
# EMAIL
# ============================================
RESEND_API_KEY=
RESEND_FROM_EMAIL=GlobalScholar AI <noreply@globalscholar.ai>

# ============================================
# ANALYTICS
# ============================================
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# ============================================
# PUSH NOTIFICATIONS
# ============================================
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY=
FIREBASE_CLIENT_EMAIL=

# ============================================
# RATE LIMITING (optional)
# ============================================
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
